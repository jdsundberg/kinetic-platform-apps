{
  "name": "Sandwich Shop",
  "slug": "sandwich-shop",
  "description": "Sandwich shop management with menu, orders, employees, and daily specials.",
  "forms": [
    {
      "slug": "recipes",
      "name": "Recipes",
      "fields": [
        {
          "name": "Name",
          "required": true
        },
        {
          "name": "Category"
        },
        {
          "name": "Ingredients",
          "rows": 3
        },
        {
          "name": "Instructions",
          "rows": 3
        },
        {
          "name": "Price"
        },
        {
          "name": "Active"
        }
      ],
      "description": "Menu recipes",
      "submissionLabelExpression": "${values('Name')} (${values('Category')})",
      "indexes": {
        "single": [
          "values[Active]",
          "values[Category]"
        ],
        "compound": [
          [
            "values[Category]",
            "values[Active]"
          ]
        ]
      }
    },
    {
      "slug": "employees",
      "name": "Employees",
      "fields": [
        {
          "name": "Name",
          "required": true
        },
        {
          "name": "Role"
        },
        {
          "name": "Phone"
        },
        {
          "name": "Email"
        },
        {
          "name": "Hire Date"
        },
        {
          "name": "Status"
        }
      ],
      "description": "Staff directory",
      "submissionLabelExpression": "${values('Name')} - ${values('Role')}",
      "indexes": {
        "single": [
          "values[Role]",
          "values[Status]"
        ],
        "compound": [
          [
            "values[Role]",
            "values[Status]"
          ]
        ]
      }
    },
    {
      "slug": "customer-feedback",
      "name": "Customer Feedback",
      "fields": [
        {
          "name": "Customer Name",
          "required": true
        },
        {
          "name": "Date"
        },
        {
          "name": "Rating"
        },
        {
          "name": "Meal Ordered"
        },
        {
          "name": "Comments",
          "rows": 3
        }
      ],
      "description": "Customer reviews and feedback",
      "submissionLabelExpression": "${values('Customer Name')} - ${values('Rating')}"
    }
  ],
  "category": "Retail"
}
