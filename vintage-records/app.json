{
  "name": "Vintage Records",
  "slug": "vintage-records",
  "description": "Vintage vinyl inventory, employee schedules, customer ratings, in-store coffee shop & sell-offer storefront",
  "category": "Retail",
  "icon": "vinyl",
  "color": "#5C1A2B",
  "bg": "#FAF6EE",
  "forms": [
    {
      "slug": "records",
      "name": "Records",
      "description": "Vintage vinyl inventory",
      "fields": [
        {
          "name": "Title",
          "required": true
        },
        {
          "name": "Artist",
          "required": true
        },
        {
          "name": "Genre"
        },
        {
          "name": "Year"
        },
        {
          "name": "Label"
        },
        {
          "name": "Condition"
        },
        {
          "name": "Price"
        },
        {
          "name": "Stock"
        },
        {
          "name": "Cover URL"
        },
        {
          "name": "Description",
          "rows": 3
        },
        {
          "name": "Status"
        }
      ],
      "submissionLabelExpression": "${values('Artist')} — ${values('Title')} (${values('Year')})",
      "indexes": {
        "single": [
          "values[Genre]",
          "values[Artist]",
          "values[Condition]",
          "values[Status]"
        ],
        "compound": [
          [
            "values[Status]",
            "values[Genre]"
          ]
        ]
      }
    },
    {
      "slug": "employees",
      "name": "Employees",
      "description": "Store staff directory",
      "fields": [
        {
          "name": "Name",
          "required": true
        },
        {
          "name": "Role"
        },
        {
          "name": "Email"
        },
        {
          "name": "Phone"
        },
        {
          "name": "Hire Date"
        },
        {
          "name": "Hourly Rate"
        },
        {
          "name": "Status"
        }
      ],
      "submissionLabelExpression": "${values('Name')} — ${values('Role')}",
      "indexes": {
        "single": [
          "values[Role]",
          "values[Status]"
        ],
        "compound": []
      }
    },
    {
      "slug": "schedules",
      "name": "Schedules",
      "description": "Employee shift schedule",
      "fields": [
        {
          "name": "Employee",
          "required": true
        },
        {
          "name": "Shift Date",
          "required": true
        },
        {
          "name": "Start Time"
        },
        {
          "name": "End Time"
        },
        {
          "name": "Role"
        },
        {
          "name": "Notes",
          "rows": 2
        }
      ],
      "submissionLabelExpression": "${values('Employee')} — ${values('Shift Date')} ${values('Start Time')}",
      "indexes": {
        "single": [
          "values[Employee]",
          "values[Shift Date]",
          "values[Role]"
        ],
        "compound": [
          [
            "values[Shift Date]",
            "values[Employee]"
          ]
        ]
      }
    },
    {
      "slug": "ratings",
      "name": "Ratings",
      "description": "Customer ratings and reviews",
      "fields": [
        {
          "name": "Customer Name",
          "required": true
        },
        {
          "name": "Rating",
          "required": true
        },
        {
          "name": "Review",
          "rows": 3
        },
        {
          "name": "Record Title"
        },
        {
          "name": "Record Artist"
        },
        {
          "name": "Review Type"
        },
        {
          "name": "Review Date"
        }
      ],
      "submissionLabelExpression": "${values('Customer Name')} — ${values('Rating')}★",
      "indexes": {
        "single": [
          "values[Rating]",
          "values[Review Type]",
          "values[Record Artist]"
        ],
        "compound": []
      }
    },
    {
      "slug": "coffee-menu",
      "name": "Coffee Menu",
      "description": "In-store coffee shop menu items",
      "fields": [
        {
          "name": "Item Name",
          "required": true
        },
        {
          "name": "Category"
        },
        {
          "name": "Price"
        },
        {
          "name": "Description",
          "rows": 2
        },
        {
          "name": "Available"
        }
      ],
      "submissionLabelExpression": "${values('Item Name')} — $${values('Price')}",
      "indexes": {
        "single": [
          "values[Category]",
          "values[Available]"
        ],
        "compound": []
      }
    },
    {
      "slug": "coffee-orders",
      "name": "Coffee Orders",
      "description": "Coffee shop customer orders",
      "fields": [
        {
          "name": "Customer Name",
          "required": true
        },
        {
          "name": "Items",
          "rows": 2
        },
        {
          "name": "Total"
        },
        {
          "name": "Status"
        },
        {
          "name": "Order Date"
        },
        {
          "name": "Notes",
          "rows": 2
        }
      ],
      "submissionLabelExpression": "${values('Customer Name')} — $${values('Total')}",
      "indexes": {
        "single": [
          "values[Status]",
          "values[Order Date]"
        ],
        "compound": []
      }
    },
    {
      "slug": "sell-offers",
      "name": "Sell Offers",
      "description": "Customer offers to sell records to the store",
      "fields": [
        {
          "name": "Customer Name",
          "required": true
        },
        {
          "name": "Contact Email",
          "required": true
        },
        {
          "name": "Contact Phone"
        },
        {
          "name": "Record Title",
          "required": true
        },
        {
          "name": "Artist",
          "required": true
        },
        {
          "name": "Year"
        },
        {
          "name": "Condition"
        },
        {
          "name": "Asking Price"
        },
        {
          "name": "Notes",
          "rows": 3
        },
        {
          "name": "Status"
        }
      ],
      "submissionLabelExpression": "${values('Artist')} — ${values('Record Title')} from ${values('Customer Name')}",
      "indexes": {
        "single": [
          "values[Status]",
          "values[Condition]"
        ],
        "compound": []
      }
    }
  ]
}
