{
  "name": "ServiceNow",
  "slug": "servicenow",
  "description": "ServiceNow-equivalent data model on the Kinetic Platform: ITSM, CSM, HRSD, CMDB, GRC, SecOps, Catalog, SPM, Procurement, Knowledge, Legal, EA and ITOM business records. Backs the Kinetic-rewritten Happy Platform Skills.",
  "category": "Enterprise",
  "icon": "server",
  "color": "#1B5E7C",
  "bg": "#E1F0F5",
  "forms": [
    {
      "slug": "incident",
      "name": "Incident",
      "description": "ITSM incident records (table: incident)",
      "submissionLabelExpression": "${values('Number')} - ${values('Short Description')}",
      "fields": [
        { "name": "Number" }, { "name": "Short Description", "required": true }, { "name": "Description", "rows": 3 },
        { "name": "State" }, { "name": "Priority" }, { "name": "Impact" }, { "name": "Urgency" }, { "name": "Category" },
        { "name": "Assignment Group" }, { "name": "Assigned To" }, { "name": "Caller" }, { "name": "CMDB CI" },
        { "name": "Opened At" }, { "name": "Resolved At" }, { "name": "Resolution Code" }, { "name": "Close Notes", "rows": 2 }
      ],
      "indexes": {
        "single": ["values[Number]", "values[State]", "values[Priority]", "values[Category]", "values[Assignment Group]", "values[Assigned To]"],
        "compound": [["values[State]", "values[Assignment Group]"], ["values[State]", "values[Priority]"]]
      }
    },
    {
      "slug": "problem",
      "name": "Problem",
      "description": "ITSM problem records (table: problem)",
