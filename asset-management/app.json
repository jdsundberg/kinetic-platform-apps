{
  "name": "Asset Management",
  "slug": "asset-management",
  "description": "IT asset lifecycle management and inventory tracking.",
  "forms": [
    {
      "slug": "assets",
      "name": "Assets",
      "fields": [
        {
          "name": "Asset ID"
        },
        {
          "name": "Asset Name",
          "required": true
        },
        {
          "name": "Category"
        },
        {
          "name": "Status"
        },
        {
          "name": "Assigned To"
        },
        {
          "name": "Department"
        },
        {
          "name": "Location"
        },
        {
          "name": "Current Value"
        },
        {
          "name": "Subcategory"
        },
        {
          "name": "Serial Number"
        },
        {
          "name": "Manufacturer"
        },
        {
          "name": "Model"
        },
        {
          "name": "Condition"
        },
        {
          "name": "Purchase Date"
        },
        {
          "name": "Purchase Cost"
        },
        {
          "name": "Salvage Value"
        },
        {
          "name": "Useful Life"
        },
        {
          "name": "Warranty Type"
        },
        {
          "name": "Warranty Provider"
        },
        {
          "name": "Warranty Start"
        },
        {
          "name": "Warranty Expiration"
        },
        {
          "name": "Related Assets"
        },
        {
          "name": "Notes",
          "rows": 3
        },
        {
          "name": "Last Audit Date"
        }
      ],
      "description": "Asset inventory records",
      "submissionLabelExpression": "${values('Asset ID')} - ${values('Asset Name')}",
      "indexes": {
        "single": [
          "values[Category]",
          "values[Status]"
        ],
        "compound": [
          [
            "values[Status]",
            "values[Category]"
          ]
        ]
      }
    }
  ],
  "category": "Operations"
}
