{
  "name": "Golf Shop",
  "slug": "golf-shop",
  "description": "Golf pro shop management with inventory, tee times, members, and bay scheduling.",
  "forms": [
    {
      "slug": "inventory",
      "name": "Inventory",
      "fields": [
        {
          "name": "Item Name"
        },
        {
          "name": "Category"
        },
        {
          "name": "Brand"
        },
        {
          "name": "SKU"
        },
        {
          "name": "Price"
        },
        {
          "name": "Quantity"
        },
        {
          "name": "Reorder Level"
        },
        {
          "name": "Status"
        },
        {
          "name": "Description"
        }
      ],
      "submissionLabelExpression": "${values[\"Item Name\"]} - ${values[\"SKU\"]}",
      "indexes": {
        "single": [
          "values[Category]",
          "values[Status]"
        ],
        "compound": [
          [
            "values[Category]",
            "values[Status]"
          ]
        ]
      }
    },
    {
      "slug": "employees",
      "name": "Employees",
      "fields": [
        {
          "name": "Name"
        },
        {
          "name": "Role"
        },
        {
          "name": "Email"
        },
        {
          "name": "Phone"
        },
        {
          "name": "Hire Date"
        },
        {
          "name": "Certification"
        },
        {
          "name": "Hourly Rate"
        },
        {
          "name": "Status"
        }
      ],
      "submissionLabelExpression": "${values[\"Name\"]} - ${values[\"Role\"]}",
      "indexes": {
        "single": [
          "values[Role]",
          "values[Status]"
        ],
        "compound": [
          [
            "values[Role]",
            "values[Status]"
          ]
        ]
      }
    },
    {
      "slug": "bay-schedule",
      "name": "Bay Schedule",
      "fields": [
        {
          "name": "Bay"
        },
        {
          "name": "Date"
        },
        {
          "name": "Time Slot"
        },
        {
          "name": "Duration"
        },
        {
          "name": "Customer Name"
        },
        {
          "name": "Customer Phone"
        },
        {
          "name": "Employee"
        },
        {
          "name": "Status"
        },
        {
          "name": "Notes"
        }
      ],
      "submissionLabelExpression": "${values[\"Bay\"]} - ${values[\"Date\"]} ${values[\"Time Slot\"]} - ${values[\"Customer Name\"]}",
      "indexes": {
        "single": [
          "values[Date]"
        ],
        "compound": []
      }
    },
    {
      "slug": "customers",
      "name": "Customers",
      "fields": [
        {
          "name": "Name"
        },
        {
          "name": "Email"
        },
        {
          "name": "Phone"
        },
        {
          "name": "Membership"
        },
        {
          "name": "Notes"
        }
      ],
      "submissionLabelExpression": "${values[\"Name\"]} (${values[\"Membership\"]})",
      "indexes": {
        "single": [
          "values[Membership]"
        ],
        "compound": []
      }
    }
  ],
  "category": "Retail"
}
