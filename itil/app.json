{
  "name": "ITSM Console",
  "slug": "itsm",
  "description": "IT service management with incidents, problems, changes, and service requests.",
  "forms": [
    {
      "slug": "incidents",
      "name": "Incidents",
      "fields": [
        { "name": "Incident Number" },
        { "name": "Title" },
        { "name": "Description", "rows": 3 },
        { "name": "Status" },
        { "name": "Priority" },
        { "name": "Severity" },
        { "name": "Service" },
        { "name": "Assigned To" },
        { "name": "Assigned Team" },
        { "name": "Reporter" },
        { "name": "Resolution", "rows": 3 },
        { "name": "Resolved Date" }
      ],
      "indexes": {
        "single": ["values[Status]", "values[Priority]", "values[Severity]", "values[Service]"],
        "compound": [["values[Status]", "values[Priority]"]]
      }
    },
    {
      "slug": "requests",
      "name": "Service Requests",
      "fields": [
        { "name": "Request Number" },
        { "name": "Title" },
        { "name": "Description", "rows": 3 },
        { "name": "Status" },
        { "name": "Priority" },
        { "name": "Service" },
        { "name": "Requested By" },
        { "name": "Assigned To" },
        { "name": "Fulfillment Notes", "rows": 3 }
      ],
      "indexes": {
        "single": ["values[Status]", "values[Priority]"],
        "compound": []
      }
    },
    {
      "slug": "change-requests",
      "name": "Change Requests",
      "fields": [
        { "name": "Change Number" },
        { "name": "Title" },
        { "name": "Description", "rows": 3 },
        { "name": "Status" },
        { "name": "Type" },
        { "name": "Risk" },
        { "name": "Priority" },
        { "name": "Service" },
        { "name": "Requested By" },
        { "name": "Assigned To" },
        { "name": "Assigned Team" },
        { "name": "Implementation Plan", "rows": 3 },
        { "name": "Backout Plan", "rows": 3 },
        { "name": "Scheduled Start" },
        { "name": "Scheduled End" }
      ],
      "indexes": {
        "single": ["values[Status]", "values[Type]", "values[Risk]"],
        "compound": [["values[Status]", "values[Type]"]]
      }
    },
    {
      "slug": "change-approvals",
      "name": "Change Approvals",
      "fields": [
        { "name": "Change Number" },
        { "name": "Approver" },
        { "name": "Status" },
        { "name": "Decision Date" },
        { "name": "Notes", "rows": 3 }
      ],
      "indexes": {
        "single": ["values[Change Number]", "values[Status]"],
        "compound": []
      }
    },
    {
      "slug": "articles",
      "name": "Knowledge Articles",
      "fields": [
        { "name": "Article Number" },
        { "name": "Title" },
        { "name": "Content", "rows": 8 },
        { "name": "Category" },
        { "name": "Status" },
        { "name": "Author" },
        { "name": "Tags" },
        { "name": "Views" },
        { "name": "Published Date" },
        { "name": "Related Service" }
      ],
      "indexes": {
        "single": ["values[Category]", "values[Status]"],
        "compound": []
      }
    },
    {
      "slug": "people",
      "name": "People",
      "fields": [
        { "name": "Full Name" },
        { "name": "Email" },
        { "name": "Title" },
        { "name": "Department" }
      ],
      "indexes": {
        "single": ["values[Email]", "values[Full Name]"],
        "compound": []
      }
    }
  ],
  "category": "Operations"
}
