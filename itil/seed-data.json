  "articles": [
    {
      "Article Number": "KB-001",
      "Title": "How to connect to VPN from home",
      "Content": "Step 1: Download GlobalProtect client from the IT portal. Step 2: Enter the VPN gateway address: vpn.company.com. Step 3: Log in with your company credentials and MFA code. Step 4: Select 'Connect' to establish the tunnel.",
      "Tags": "vpn, remote, connectivity",
      "Category": "Network & Connectivity",
      "Status": "Published",
      "Views": "342",
      "Author": "Sarah Chen",
      "Published Date": "2025-06-15",
      "Related Service": "Network & Connectivity"
    },
    {
      "Article Number": "KB-002",
      "Title": "Resetting your password via self-service",
      "Content": "Navigate to password.company.com. Click 'Forgot Password'. Enter your email address and answer your security questions. A reset link will be sent to your registered email. Links expire after 15 minutes.",
      "Tags": "password, reset, account",
      "Category": "Account & Access",
      "Status": "Published",
      "Views": "891",
      "Author": "Mark Thompson",
      "Published Date": "2025-03-10",
      "Related Service": "Account & Access"
    },
    {
      "Article Number": "KB-003",
      "Title": "Setting up a new printer on Windows",
      "Content": "Open Settings > Printers & scanners. Click Add a printer. Select the network printer from the list or enter the IP address manually. Install the driver when prompted. Print a test page to verify.",
      "Tags": "printer, setup, windows",
      "Category": "Hardware",
      "Status": "Published",
      "Views": "156",
      "Author": "Mike Torres",
      "Published Date": "2025-09-20",
      "Related Service": "Printing"
    },
    {
      "Article Number": "KB-004",
      "Title": "Requesting software through the IT portal",
      "Content": "Log in to the IT self-service portal. Navigate to Service Catalog > Software Requests. Select the software you need. Fill in the business justification. Submit for manager approval. Typical turnaround is 2-3 business days.",
      "Tags": "software, request, portal",
      "Category": "Software",
      "Status": "Published",
      "Views": "224",
      "Author": "Mark Thompson",
      "Published Date": "2025-05-05",
      "Related Service": "Software"
    },
    {
      "Article Number": "KB-005",
      "Title": "Troubleshooting Zoom audio issues",
      "Content": "Check that your microphone is not muted. Verify the correct audio device is selected in Zoom Settings > Audio. Test your speaker and microphone. If using Bluetooth, ensure it is paired and connected. Restart Zoom if issues persist.",
      "Tags": "zoom, audio, troubleshooting, video conferencing",
      "Category": "Audio & Video Conferencing",
      "Status": "Published",
      "Views": "413",
      "Author": "Mike Torres",
      "Published Date": "2025-07-12",
      "Related Service": "Audio & Video Conferencing"
    },
    {
      "Article Number": "KB-006",
      "Title": "Mobile device enrollment for company email",
      "Content": "Download Microsoft Authenticator from your app store. Open your company email app and add your work account. Follow the Intune enrollment prompts. Accept the device management policy. Your email, calendar, and contacts will sync within 5 minutes.",
      "Tags": "mobile, email, enrollment, intune",
      "Category": "Mobile Devices",
      "Status": "Published",
      "Views": "187",
      "Author": "Mike Torres",
      "Published Date": "2025-08-01",
      "Related Service": "Mobile Devices"
    },
    {
      "Article Number": "KB-007",
      "Title": "AWS IAM best practices for developers",
      "Content": "Use IAM roles instead of long-lived access keys. Enable MFA for all console users. Follow the principle of least privilege. Rotate credentials regularly. Use AWS Organizations for multi-account management.",
      "Tags": "aws, iam, security, cloud, best practices",
      "Category": "Cloud Services",
      "Status": "Draft",
      "Views": "45",
      "Author": "David Kim",
      "Published Date": "",
      "Related Service": "Cloud Services"
    },
    {
      "Article Number": "KB-008",
      "Title": "How to report a security incident",
      "Content": "If you suspect a security breach, immediately contact the Security Operations Center at security@company.com or ext. 5555. Do not attempt to investigate on your own. Preserve any evidence (screenshots, emails). Document the timeline of events.",
      "Tags": "security, incident, reporting",
      "Category": "Security",
      "Status": "Published",
      "Views": "298",
      "Author": "Mark Thompson",
      "Published Date": "2025-04-20",
      "Related Service": "Security"
    },
    {
      "Article Number": "KB-009",
      "Title": "Configuring email signatures in Outlook",
      "Content": "Open Outlook and go to File > Options > Mail > Signatures. Click New to create a signature. Use the company template from the brand portal. Set it as default for new messages and replies. Apply to all email accounts.",
      "Tags": "email, signature, outlook, branding",
      "Category": "Email & Calendar",
      "Status": "Published",
      "Views": "176",
      "Author": "Sarah Chen",
      "Published Date": "2025-10-15",
      "Related Service": "Email & Calendar"
    },
    {
      "Article Number": "KB-010",
      "Title": "Network drive mapping for new employees",
      "Content": "Open File Explorer. Right-click This PC and select Map network drive. Enter the server path provided by IT. Check Reconnect at sign-in. Enter your network credentials when prompted.",
      "Tags": "network drive, mapping, onboarding",
      "Category": "Network & Connectivity",
      "Status": "Published",
      "Views": "445",
      "Author": "Sarah Chen",
      "Published Date": "2025-02-28",
      "Related Service": "Network & Connectivity"
    }
