        { "name": "Category Name" },
        { "name": "Description" },
        { "name": "Icon" },
        { "name": "Sort Order" }
      ],
      "indexes": {
        "single": [],
        "compound": []
      }
    },
    {
      "slug": "article-versions",
      "name": "Article Versions",
      "fields": [
        { "name": "Version ID" },
        { "name": "Article ID" },
        { "name": "Article Title" },
        { "name": "Version Number" },
