        { "name": "Author" },
        { "name": "Status" }
      ],
      "indexes": {
        "single": ["values[Article ID]"],
        "compound": []
      }
    },
    {
      "slug": "article-comments",
      "name": "Article Comments",
      "fields": [
        { "name": "Comment ID" },
        { "name": "Article ID" },
        { "name": "Article Title" },
        { "name": "Author" },
        { "name": "Content", "rows": 3 },
        { "name": "Status" },
        { "name": "Category Name" }
      ],
      "indexes": {
        "single": ["values[Article ID]"],
        "compound": []
