          "name": "Article Number"
        },
        {
          "name": "Title"
        },
        {
          "name": "Content",
          "rows": 8
        },
        {
          "name": "Category"
        },
        {
          "name": "Status"
        },
        {
          "name": "Author"
        },
        {
          "name": "Tags"
        },
        {
          "name": "Views"
        },
        {
          "name": "Published Date"
        },
        {
          "name": "Related Service"
        }
      ],
      "description": "Knowledge base articles",
      "submissionLabelExpression": "${values('Article Number')} - ${values('Title')}",
      "indexes": {
        "single": [
