  "lessons-learned": [
    { "Project": "Credentialing System", "Customer": "Northwell Health", "Category": "Scope", "Title": "Formal change request process needed", "Description": "Mid-project scope additions (automated license verification) caused schedule slip. Should have triggered formal change request with timeline/budget impact assessment before accepting.", "Impact": "High", "Reusable": "Yes", "Tags": "scope,change-management,process" },
    { "Project": "Credentialing System", "Customer": "Northwell Health", "Category": "Integration", "Title": "State licensing API variability", "Description": "License verification APIs vary significantly by state. Some have REST APIs, some require SOAP, some have no API at all. Build in discovery time for each integration.", "Impact": "Medium", "Reusable": "Yes", "Tags": "integration,healthcare,api" },
    { "Project": "Knowledge Base Portal", "Customer": "Bank of the West", "Category": "Delivery", "Title": "Simple scope finishes faster than estimated", "Description": "Well-defined, simple scope with clear boundaries consistently finishes ahead of schedule. Consider using as baseline for future KB engagements.", "Impact": "Medium", "Reusable": "Yes", "Tags": "estimation,knowledge-base,scope" },
    { "Project": "IT Service Management", "Customer": "Bank of the West", "Category": "Integration", "Title": "Validate integration APIs early", "Description": "Assumed legacy CMDB had REST API based on customer description. Reality: no API exists. Always validate integration endpoints during discovery, not during build.", "Impact": "High", "Reusable": "Yes", "Tags": "integration,discovery,validation" }
  ],
