        {
          "name": "Consumers"
        },
        {
          "name": "SLA Tier"
        },
        {
          "name": "Criticality"
        },
        {
          "name": "Platform"
        },
        {
          "name": "Status"
        },
        {
          "name": "Tags"
        }
      ],
      "description": "Data products consuming datasets, SLAs, criticality",
      "submissionLabelExpression": "${values('Name')}"
    },
    {
      "slug": "access-requests",
      "name": "Access Requests",
      "fields": [
        {
          "name": "Requestor",
