        {
          "name": "Due Date"
        },
        {
          "name": "Resolved Date"
        }
      ],
      "description": "Security finding tracking and remediation",
      "submissionLabelExpression": "${values('Title')} - ${values('Severity')}"
    },
    {
      "slug": "lineage",
      "name": "Lineage",
      "fields": [
        {
          "name": "Source Dataset",
          "required": true
        },
        {
          "name": "Target Dataset",
          "required": true
        },
        {
          "name": "Transform Type"
        },
        {
          "name": "Platform"
        },
        {
          "name": "Frequency"
        },
        {
          "name": "Status"
        },
        {
          "name": "Description",
          "rows": 2
        }
      ],
      "description": "Upstream/downstream data lineage",
      "submissionLabelExpression": "${values('Source Dataset')} -> ${values('Target Dataset')}"
