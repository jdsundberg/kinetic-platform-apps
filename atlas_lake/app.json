{
  "name": "Atlas Lake",
  "slug": "atlas-lake",
  "description": "Data lake management with pipelines, schemas, quality rules, and access controls.",
  "forms": [
    {
      "slug": "platforms",
      "name": "Platforms",
      "fields": [
        {
          "name": "Name",
          "required": true
        },
        {
          "name": "Platform Type"
        },
        {
          "name": "Vendor"
        },
        {
          "name": "Environment"
        },
        {
          "name": "Region"
        },
        {
          "name": "Status"
        },
        {
          "name": "Owner"
        },
        {
          "name": "Cost Center"
        },
        {
          "name": "Description",
          "rows": 3
        },
        {
          "name": "Tags"
        }
      ],
      "description": "Data platform infrastructure",
      "submissionLabelExpression": "${values('Name')} - ${values('Platform Type')}"
    },
    {
      "slug": "domains",
      "name": "Domains",
      "fields": [
        {
          "name": "Name",
          "required": true
        },
        {
          "name": "Description",
