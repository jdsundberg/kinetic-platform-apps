{
  "name": "CMDB",
  "slug": "cmdb",
  "description": "Configuration Management Database — system of record for CIs, relationships & service maps (consumed by other apps via WebAPIs + routines)",
  "category": "Foundation",
  "icon": "database",
  "color": "#7C3AED",
  "bg": "#F3E8FF",
  "forms": [
    {
      "slug": "ci-classes",
      "name": "CI Classes",
      "description": "Catalog of Configuration Item classes (Server, Database, Application, Service, etc.) — schema definitions used by CIs.",
      "submissionLabelExpression": "${values('Class Name')}",
      "fields": [
        {
          "name": "Class Name"
        },
        {
          "name": "Form Slug"
        },
        {
          "name": "Parent Class"
        },
        {
          "name": "Category"
        },
        {
          "name": "Icon"
        },
        {
          "name": "Color"
        },
        {
          "name": "Description",
          "rows": 3
        },
        {
          "name": "Default Criticality"
        },
        {
          "name": "Status"
        }
      ],
      "indexes": {
        "single": [
          "values[Class Name]",
          "values[Form Slug]",
          "values[Category]",
          "values[Status]"
        ],
        "compound": []
      }
    },
