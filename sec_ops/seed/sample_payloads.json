  "incident_transition": {
    "endpoint": "POST /api/secops/incidents/{submission_id}/transition",
    "description": "Transition an incident to the next lifecycle state.",
    "valid_transitions": {
      "New": ["In Progress"],
      "In Progress": ["Contained"],
      "Contained": ["Eradicated"],
      "Eradicated": ["Recovered"],
      "Recovered": ["Closed"]
    },
    "request_example": {
      "new_status": "Contained",
      "notes": "Isolated affected servers web-prod-01 and web-prod-02 from network. Blocked egress to C2 IP 45.33.32.156 at firewall. All credentials on affected systems queued for rotation.",
      "user": "s.chen"
    },
    "response_example": {
      "success": true,
      "previous_status": "In Progress",
      "new_status": "Contained"
    },
    "error_example": {
      "error": "Cannot transition from New to Contained"
    }
  },
  "risk_acceptance": {
    "endpoint": "POST /api/secops/vulns/{submission_id}/accept-risk",
    "description": "Accept risk for a vulnerability finding. Requires GRC approval.",
    "request_example": {
      "reason": "Legacy system scheduled for decommission in Q2 2026. Compensating controls in place: network segmentation, enhanced monitoring, WAF rules deployed.",
      "expiry": "2026-06-30",
      "approved_by": "l.thompson"
    },
    "response_example": {
      "success": true
    }
  },
  "playbook_run": {
    "endpoint": "POST /api/secops/playbooks/{playbook_submission_id}/run",
    "description": "Execute a playbook against a target entity.",
    "request_example": {
      "target_type": "Incident",
      "target_id": "incident-submission-id-here",
      "executed_by": "s.chen"
    },
    "response_example": {
      "success": true,
      "run_id": "run-submission-id-here"
    }
  },
  "audit_event": {
    "endpoint": "POST /api/secops/audit",
    "description": "Create an audit trail event.",
    "request_example": {
      "entity_type": "Incident",
      "entity_id": "incident-submission-id",
      "actor": "s.chen",
      "action": "Assigned commander to j.martinez",
      "details": "Changed commander from unassigned to j.martinez for SEC-00001",
      "entity_title": "SEC-00001"
    },
    "response_example": {
      "success": true,
      "id": "audit-event-submission-id"
    }
  }
