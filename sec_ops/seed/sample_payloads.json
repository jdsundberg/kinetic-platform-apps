{
  "alert_ingest": {
    "endpoint": "POST /api/secops/alerts/ingest",
    "description": "Ingest security alerts from SIEM/EDR/scanner sources. Accepts single object or array.",
    "single_alert_example": {
      "source": "CrowdStrike",
      "external_alert_id": "CS-2026-88431",
      "severity": "High",
      "category": "Malware",
      "title": "Suspicious PowerShell execution detected",
      "description": "PowerShell process spawned with encoded command line arguments, potential fileless malware execution on endpoint laptop-sales-01.",
      "asset_id": "laptop-sales-01",
      "hostname": "laptop-sales-01",
      "ip_address": "10.20.5.44",
      "environment": "Prod",
      "asset_criticality": 3,
      "user_id": "m.johnson",
      "indicators": ["powershell.exe", "encoded_command", "10.20.5.44", "c2-callback.evil.com"],
      "raw_payload": {
        "detection_id": "ldt:abc123:88431",
        "process_name": "powershell.exe",
        "command_line": "powershell -enc UwB0AGEAcgB0AC0A...",
        "parent_process": "outlook.exe",
        "severity_score": 75
      }
    },
    "batch_example": [
      {
        "source": "Splunk",
        "external_alert_id": "SPL-ALERT-99281",
        "severity": "Critical",
        "category": "Data Exfiltration",
        "title": "Unusual outbound data transfer from database server",
        "description": "db-prod-01 transferred 2.3GB to external IP 45.33.32.156 over port 443 in the last hour.",
        "asset_id": "db-prod-01",
        "hostname": "db-prod-01",
        "ip_address": "10.10.1.20",
        "environment": "Prod",
        "asset_criticality": 5,
        "indicators": ["45.33.32.156", "db-prod-01", "port-443", "large-transfer"]
      },
      {
        "source": "Sentinel",
        "external_alert_id": "SENT-2026-44120",
        "severity": "Medium",
        "category": "Identity",
        "title": "Failed login attempts from unusual location",
        "description": "User j.smith had 15 failed login attempts from IP 185.220.101.34 (TOR exit node).",
        "user_id": "j.smith",
        "hostname": "azure-ad",
        "indicators": ["185.220.101.34", "tor-exit-node", "j.smith"]
      }
    ],
    "phishing_example": {
      "source": "Sentinel",
      "external_alert_id": "SENT-2026-44200",
      "severity": "High",
      "category": "Phishing",
      "title": "Phishing email with credential harvesting link",
      "description": "User r.williams received email from spoofed sender with link to fake O365 login page.",
      "user_id": "r.williams",
      "hostname": "mail-prod-01",
      "indicators": ["phish-domain.com", "fake-o365-login", "r.williams@company.com"],
      "asset_criticality": 2
    },
    "response_example": {
      "success": true,
      "results": [
        {
          "action": "created",
          "id": "abc123-def456-...",
          "dedupe_hash": "a1b2c3d4e5f6g7h8",
          "auto_action": {
            "type": "incident_created",
            "incident_id": "xyz789-...",
            "severity": "S2"
          }
        },
        {
          "action": "deduplicated",
          "id": "existing-id-...",
          "count": 3
        }
      ]
    }
  },
