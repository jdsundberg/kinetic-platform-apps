        {
          "name": "Tenant ID"
        },
        {
          "name": "Name",
          "required": true
        },
        {
          "name": "Industry"
        },
        {
          "name": "Regulatory Drivers"
        },
        {
          "name": "Contract Requirements",
          "rows": 2
        },
        {
          "name": "Frameworks"
        },
        {
          "name": "Engagement Owner"
        },
        {
          "name": "Primary Contact"
        },
        {
          "name": "Contact Email"
        },
        {
          "name": "Readiness Score"
        },
        {
          "name": "Risk Score"
        },
        {
          "name": "Open Gaps"
        },
        {
          "name": "Overdue Tasks"
        },
        {
          "name": "Evidence Missing"
        },
        {
          "name": "Project Health"
        },
        {
          "name": "Audit Date"
        },
        {
          "name": "Last Review Date"
        },
        {
          "name": "Next Review Date"
        },
        {
          "name": "Status"
        },
        {
          "name": "Color"
