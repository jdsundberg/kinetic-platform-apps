    {
      "slug": "control",
      "name": "Control",
      "description": "Reusable control library entry, keyed by framework + control id.",
      "submissionLabelExpression": "${values('Framework')} ${values('Control ID')}",
      "fields": [
        {
          "name": "Control Key"
        },
        {
          "name": "Framework"
        },
        {
          "name": "Control ID"
        },
        {
          "name": "Control Family"
        },
        {
          "name": "Title",
          "required": true
        },
        {
          "name": "Requirement Text",
          "rows": 3
        },
        {
          "name": "Plain English",
          "rows": 2
        },
        {
          "name": "Implementation Guidance",
          "rows": 3
        },
        {
          "name": "Evidence Examples",
          "rows": 2
