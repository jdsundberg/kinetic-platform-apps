  "bike-trails": [
    { "Name": "Slickrock Trail",          "City": "Moab",            "State": "UT", "Length Miles": "10.5", "Elevation Gain": "1450", "Difficulty": "Expert",   "Surface": "Slickrock",   "Lat": "38.58",  "Lng": "-109.50", "Status": "Open",              "Description": "Iconic Navajo sandstone loop on the Sand Flats above Moab. Bring tubeless tires and water." },
    { "Name": "Katy Trail",               "City": "Clinton",         "State": "MO", "Length Miles": "240",  "Elevation Gain": "1200", "Difficulty": "Easy",     "Surface": "Crushed Limestone", "Lat": "38.37", "Lng": "-93.78",  "Status": "Open",              "Description": "Longest rail-trail in the US — flat, family-friendly across central Missouri." },
    { "Name": "Great Allegheny Passage",  "City": "Cumberland",      "State": "MD", "Length Miles": "150",  "Elevation Gain": "1750", "Difficulty": "Moderate", "Surface": "Crushed Limestone", "Lat": "39.65", "Lng": "-78.76",  "Status": "Open",              "Description": "Pittsburgh to Cumberland, MD. Connects to the C&O Canal Towpath for a full DC ride." },
    { "Name": "C&O Canal Towpath",        "City": "Washington",      "State": "DC", "Length Miles": "184.5","Elevation Gain": "600",  "Difficulty": "Easy",     "Surface": "Dirt",        "Lat": "38.90",  "Lng": "-77.06",  "Status": "Open",              "Description": "Historic towpath from Georgetown to Cumberland. Mostly flat, often muddy after rain." },
    { "Name": "Tahoe Rim Trail",          "City": "South Lake Tahoe","State": "CA", "Length Miles": "165",  "Elevation Gain": "27000","Difficulty": "Expert",   "Surface": "Singletrack", "Lat": "38.94",  "Lng": "-119.98", "Status": "Open",              "Description": "Big-sky alpine singletrack circling Lake Tahoe. Bikes allowed on most segments." },
    { "Name": "Porcupine Rim",            "City": "Moab",            "State": "UT", "Length Miles": "15.5", "Elevation Gain": "3000", "Difficulty": "Expert",   "Surface": "Rock/Singletrack", "Lat": "38.62", "Lng": "-109.44", "Status": "Open",              "Description": "Classic Moab descent — Castle Valley views, exposed ledges. Shuttle from Sand Flats Road." },
    { "Name": "Whistler Bike Park East",  "City": "Park City",       "State": "UT", "Length Miles": "8",    "Elevation Gain": "0",    "Difficulty": "Hard",     "Surface": "Singletrack", "Lat": "40.65",  "Lng": "-111.50", "Status": "Open",              "Description": "Lift-served downhill at Deer Valley. Berms, jumps, and machine-built flow." },
    { "Name": "Galbraith Mountain",       "City": "Bellingham",      "State": "WA", "Length Miles": "65",   "Elevation Gain": "5800", "Difficulty": "Hard",     "Surface": "Singletrack", "Lat": "48.72",  "Lng": "-122.43", "Status": "Open",              "Description": "PNW loam network above Bellingham. Tight tech, rooty descents, year-round rideable." },
    { "Name": "Pisgah Black Mountain",    "City": "Brevard",         "State": "NC", "Length Miles": "12",   "Elevation Gain": "2400", "Difficulty": "Expert",   "Surface": "Singletrack", "Lat": "35.28",  "Lng": "-82.79",  "Status": "Open",              "Description": "Pisgah classic — rocks, roots, creek crossings. Earn-your-turns climb up Clawhammer." },
    { "Name": "Burke-Gilman Trail",       "City": "Seattle",         "State": "WA", "Length Miles": "20",   "Elevation Gain": "300",  "Difficulty": "Easy",     "Surface": "Paved",       "Lat": "47.66",  "Lng": "-122.30", "Status": "Open",              "Description": "Urban paved rail-trail along Lake Union and Lake Washington. Heavy commuter use." },
    { "Name": "Cherry Creek Trail",       "City": "Denver",          "State": "CO", "Length Miles": "42",   "Elevation Gain": "800",  "Difficulty": "Easy",     "Surface": "Paved",       "Lat": "39.72",  "Lng": "-104.96", "Status": "Open",              "Description": "Paved path from Confluence Park through downtown Denver out to Franktown." },
    { "Name": "South Mountain National",  "City": "Phoenix",         "State": "AZ", "Length Miles": "16",   "Elevation Gain": "1700", "Difficulty": "Hard",     "Surface": "Rock/Desert", "Lat": "33.34",  "Lng": "-112.05", "Status": "Open",              "Description": "Desert XC favorite — National Trail spine across South Mountain Park ridges." },
    { "Name": "Munich Trail (Marin)",     "City": "Fairfax",         "State": "CA", "Length Miles": "11",   "Elevation Gain": "1800", "Difficulty": "Moderate", "Surface": "Fire Road",   "Lat": "37.99",  "Lng": "-122.59", "Status": "Open",              "Description": "Mt. Tam fire road loop — birthplace of mountain biking. No singletrack but lots of view." },
    { "Name": "Walnut Creek MTB",         "City": "Austin",          "State": "TX", "Length Miles": "18",   "Elevation Gain": "900",  "Difficulty": "Moderate", "Surface": "Singletrack", "Lat": "30.40",  "Lng": "-97.69",  "Status": "Open",              "Description": "Tight, twisty Hill Country singletrack. Rideable year-round, hot in summer." },
    { "Name": "Phil's World",             "City": "Cortez",          "State": "CO", "Length Miles": "27",   "Elevation Gain": "1200", "Difficulty": "Moderate", "Surface": "Singletrack", "Lat": "37.34",  "Lng": "-108.51", "Status": "Open",              "Description": "Flowy, fast SW Colorado classic. 'Rib Cage' is the highlight roller section." },
