  "trail-comments": [
    { "_trailName": "Slickrock Trail",          "Customer Name": "Sarah K.",  "Rating": "5", "Comment": "Bucket-list ride. The grip on that sandstone is unreal — bring extra water, my Garmin showed 95°F at noon." },
    { "_trailName": "Slickrock Trail",          "Customer Name": "Mike R.",   "Rating": "4", "Comment": "Brutal but incredible. Tubeless saved my ride. Skip if you do not have decent skills." },
    { "_trailName": "Slickrock Trail",          "Customer Name": "Jen P.",    "Rating": "5", "Comment": "Did the whole loop in 4 hours. The Practice Loop first if it is your first time!" },
    { "_trailName": "Katy Trail",               "Customer Name": "Linda M.",  "Rating": "5", "Comment": "Did the full 240 over 5 days with my husband. Hermann to Augusta section is wine country gold." },
    { "_trailName": "Katy Trail",               "Customer Name": "Tom B.",    "Rating": "4", "Comment": "Perfect family trip. Hardly any cars to cross. Bring sunscreen — limited shade between Boonville and Pilot Grove." },
    { "_trailName": "Great Allegheny Passage",  "Customer Name": "Erin D.",   "Rating": "5", "Comment": "Did GAP+C&O end-to-end Pittsburgh to DC. Best 5 days of riding in years." },
    { "_trailName": "C&O Canal Towpath",        "Customer Name": "Erin D.",   "Rating": "4", "Comment": "Muddy after the spring rains we had this year, but otherwise a magical ride." },
    { "_trailName": "Tahoe Rim Trail",          "Customer Name": "Kevin L.",  "Rating": "5", "Comment": "The views from Marlette Lake are insane. Hike-a-bike on a few sections but worth every step." },
    { "_trailName": "Porcupine Rim",            "Customer Name": "Dave H.",   "Rating": "5", "Comment": "Take the shuttle to the top. Castle Valley overlook is one of the most photographed spots in MTB." },
    { "_trailName": "Porcupine Rim",            "Customer Name": "Anna K.",   "Rating": "3", "Comment": "Beautiful but the rock garden at the end destroyed my rear tire. Bring spares." },
    { "_trailName": "Whistler Bike Park East",  "Customer Name": "Cody M.",   "Rating": "5", "Comment": "Deer Valley flow is buttery. Tincup is the move for big airtime." },
    { "_trailName": "Galbraith Mountain",       "Customer Name": "Ryan S.",   "Rating": "5", "Comment": "PNW heaven. Hand-built tech, year-round rideable. Stop at Boundary Bay after." },
    { "_trailName": "Pisgah Black Mountain",    "Customer Name": "Marcus T.", "Rating": "4", "Comment": "Old-school Pisgah punishment. Rocks, roots, water — bring a real bike and real skills." },
    { "_trailName": "Burke-Gilman Trail",       "Customer Name": "Wendy O.",  "Rating": "4", "Comment": "Great commuter route. Watch for kids on weekends near Gas Works Park." },
    { "_trailName": "South Mountain National",  "Customer Name": "Brad F.",   "Rating": "4", "Comment": "Desert ride at its finest. Start before sunrise May-September or you will cook." },
    { "_trailName": "Phil's World",             "Customer Name": "Tina G.",   "Rating": "5", "Comment": "Rib Cage is so much fun. Easy enough to ride twice in a day." },
    { "_trailName": "Kingdom Trails",           "Customer Name": "Hannah V.", "Rating": "5", "Comment": "Vermont singletrack at its finest. Buy the pass at Kingdom HQ and support the trails." },
    { "_trailName": "Walnut Creek MTB",         "Customer Name": "Jose A.",   "Rating": "4", "Comment": "Great after-work ride in Austin. Watch for poison ivy on the unmaintained spurs." }
  ],
